## Copy this file to .env and fill the values to enable real email delivery.
## Use either SMTP (Gmail / other) OR Brevo (recommended for production).

## SMTP settings (Gmail example)
GHARSEWA_SMTP_HOST=smtp.gmail.com
GHARSEWA_SMTP_PORT=587
GHARSEWA_SMTP_USER=your-email@gmail.com
GHARSEWA_SMTP_PASS=YOUR_16_DIGIT_APP_PASSWORD
GHARSEWA_MAIL_FROM=your-email@gmail.com
GHARSEWA_MAIL_FROM_NAME=Ghar Sewa

## Optional: Brevo (Sendinblue) API key. If present, Brevo is tried first.
GHARSEWA_BREVO_API_KEY=

# Example notes:
# - For Gmail: create an App Password (Google account -> Security -> App passwords) and paste it into GHARSEWA_SMTP_PASS.
# - Make sure PHP has cURL (for Brevo) and OpenSSL enabled (for STARTTLS).
# - After copying, save as .env (do NOT commit secrets to source control).
